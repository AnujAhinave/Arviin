<script>
    const API_URL = "https://script.google.com/macros/s/AKfycby87Kh9jGLi3-2kctMIWhF1eGxLZHQAN0jIftq9SzrCysU5KuwKbMISs7VuWjvIvH9BTA/exec";

    const serviceSelect = document.getElementById('service-select');
    const dateSelect  = document.getElementById('doctor-date');
    const timeSelect  = document.getElementById('doctor-time');
    const bookingForm = document.getElementById('clinic-booking-form');
    const submitBtn   = document.getElementById('submit-btn');

    let allAvailableSlots = []; 

    async function loadSchedule() {
        try {
            const response = await fetch(API_URL + "?fetch=true");
            const data = await response.json();
            allAvailableSlots = data.slots || [];
        } catch (e) { console.error("API Error", e); }
    }

    serviceSelect.onchange = () => {
        if (!serviceSelect.value) return;
        dateSelect.innerHTML = '<option value="">LOADING...</option>';
        const uniqueDates = [...new Set(allAvailableSlots.filter(s => s.status.toLowerCase() === 'available').map(s => s.date))];
        if (uniqueDates.length > 0) {
            dateSelect.innerHTML = '<option value="">CHOOSE DATE</option>';
            uniqueDates.forEach(d => {
                let opt = document.createElement('option'); opt.value = d; opt.textContent = d;
                dateSelect.appendChild(opt);
            });
            dateSelect.disabled = false;
        }
    };

    dateSelect.onchange = () => {
        const selectedDate = dateSelect.value;
        timeSelect.innerHTML = '<option value="">SELECT TIME</option>';
        const slots = allAvailableSlots.filter(s => s.date === selectedDate);
        if (slots.length > 0) {
            slots.forEach(s => {
                let opt = document.createElement('option');
                opt.value = s.time; opt.textContent = s.time;
                opt.disabled = s.status === 'booked';
                timeSelect.appendChild(opt);
            });
            timeSelect.disabled = false;
        }
    };

    bookingForm.onsubmit = async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.textContent = "SENDING...";
        const fd = new FormData(bookingForm);
        const payload = {
            action: "newBooking",
            firstName: fd.get("firstName"),
            phone: fd.get("phone"),
            service: fd.get("service"),
            date: fd.get("selected_date"),
            time: fd.get("selected_time")
        };
        try {
            await fetch(API_URL, { method: 'POST', mode: 'no-cors', body: JSON.stringify(payload) });
            document.getElementById('booking-form-wrapper').classList.add('hidden');
            document.getElementById('thank-you-page').classList.remove('hidden');
        } catch (err) { alert("Booking notification sent!"); }
    };

    loadSchedule();
</script>
